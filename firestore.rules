rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== USERS ====================
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for contacts list)
      allow read: if request.auth != null;
      
      // Users can only create/update their own profile
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Prevent users from deleting profiles
      allow delete: if false;

      // Each signed-in app install stores its own FCM token here. This avoids
      // one device overwriting another and lets Cloud Functions clean up only
      // the stale device token that Firebase rejects.
      //
      // E2EE: this same path also stores the Signal PreKeyBundle (public).
      //   - keyBundle must be readable by ANY authenticated user (otherwise
      //     peers can't initiate a session).
      //   - Only the owner can write/update their own bundle.
      match /devices/{deviceId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;

        // One-time prekeys: readable by anyone (so we can build a bundle),
        // writable only by the owner. Atomic consume-on-read happens via
        // the consumeOneTimePreKey Cloud Function which uses the Admin SDK.
        match /oneTimePreKeys/{preKeyId} {
          allow read: if request.auth != null;
          allow create, update, delete: if request.auth != null
            && request.auth.uid == userId;
        }
      }

      // E2EE: passphrase-encrypted device-state backup. Only the owner can
      // read or write. Cloud admins see opaque ciphertext.
      match /backups/{backupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ==================== CHAT ROOMS ====================
    match /chatRooms/{chatRoomId} {
      // Helper function to check if user is participant
      function isParticipant() {
        return resource.data.participants != null 
          && request.auth.uid in resource.data.participants;
      }
      
      function willBeParticipant() {
        return request.resource.data.participants != null
          && request.auth.uid in request.resource.data.participants;
      }
      
      // Helper to check if user ID is in the chatRoomId (fallback for legacy data)
      function isUserInChatRoomId() {
        return chatRoomId.matches('.*' + request.auth.uid + '.*');
      }
      
      // Allow creating chat room if user is a participant
      allow create: if request.auth != null && willBeParticipant();
      
      // Allow reading if user is a participant OR user ID is in chatRoomId (legacy support)
      allow read: if request.auth != null && (isParticipant() || isUserInChatRoomId());
      
      // Allow updating (for last message, unread count, etc.)
      allow update: if request.auth != null && (isParticipant() || isUserInChatRoomId());
      
      // Prevent deletion of chat rooms (or allow only if participant)
      allow delete: if false;
      
      // ==================== MESSAGES ====================
      match /messages/{messageId} {
        // Helper to check parent chat room participation
        function isChatParticipant() {
          let chatRoom = get(/databases/$(database)/documents/chatRooms/$(chatRoomId));
          return chatRoom != null 
            && chatRoom.data.participants != null
            && request.auth.uid in chatRoom.data.participants;
        }
        
        // Fallback: check if user ID is in the chatRoomId
        function isUserInRoomId() {
          return chatRoomId.matches('.*' + request.auth.uid + '.*');
        }
        
        // Allow reading messages if participant or user is in room ID
        allow read: if request.auth != null && (isChatParticipant() || isUserInRoomId());
        
        // Allow creating message if user is authenticated and is sender
        allow create: if request.auth != null 
          && request.auth.uid == request.resource.data.senderId
          && (isChatParticipant() || isUserInRoomId());
        
        // Allow updating (for read receipts) if participant
        allow update: if request.auth != null 
          && (isChatParticipant() || isUserInRoomId());
        
        // Allow deleting only own messages
        allow delete: if request.auth != null 
          && request.auth.uid == resource.data.senderId;
      }
    }
    
    // ==================== CALLS ====================
    match /calls/{callId} {
      // Only participants can read call data
      allow read: if request.auth != null
        && (resource.data.callerId == request.auth.uid 
            || resource.data.calleeId == request.auth.uid);
      
      // Only the caller or callee can create a call
      allow create: if request.auth != null
        && (request.resource.data.callerId == request.auth.uid 
            || request.resource.data.calleeId == request.auth.uid);
      
      // Only participants can update call status
      allow update: if request.auth != null
        && (resource.data.callerId == request.auth.uid 
            || resource.data.calleeId == request.auth.uid);
      
      // Allow deletion by participants (cleanup after call ends)
      allow delete: if request.auth != null
        && (resource.data.callerId == request.auth.uid
            || resource.data.calleeId == request.auth.uid);

      // E2EE: per-device wrapped Agora encryption keys.
      // Sender writes; recipient reads. Doc id is "<recipientUid>:<deviceId>".
      match /keyEnvelopes/{addr} {
        allow read: if request.auth != null
          && addr.matches(request.auth.uid + ':.*');
        allow create: if request.auth != null
          && (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid
              || get(/databases/$(database)/documents/calls/$(callId)).data.calleeId == request.auth.uid);
      }
    }
    
    // ==================== STATUSES ====================
    match /statuses/{userId} {
      function isValidStatusView(viewerId) {
        return request.auth != null
          && request.auth.uid != userId
          && request.auth.uid == viewerId
          && request.resource.data.keys().hasOnly(['viewerId', 'viewedAt'])
          && request.resource.data.keys().hasAll(['viewerId', 'viewedAt'])
          && request.resource.data.viewerId == viewerId
          && request.resource.data.viewedAt is timestamp;
      }

      // Anyone authenticated can read statuses
      allow read: if request.auth != null;
      
      // Users can create/update their own status document.
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Users can only delete their own status
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /views/{statusItemId}/viewers/{viewerId} {
        allow read: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == viewerId);
        allow create, update: if isValidStatusView(viewerId);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // E2EE: wrappedKeys/{statusItemId}/envelopes/{viewerUid:deviceId}
      // Owner writes one envelope per viewer device. Viewer reads only
      // their own. Owner can delete to revoke access.
      match /wrappedKeys/{statusItemId}/envelopes/{addr} {
        allow read: if request.auth != null
          && (addr.matches(request.auth.uid + ':.*')
              || request.auth.uid == userId);
        allow create, update, delete: if request.auth != null
          && request.auth.uid == userId;
      }
    }
    
    // ==================== DEVICE SESSIONS ====================
    // Used by issueDeviceSession / exchangeDeviceSession / revokeDeviceSession
    // Cloud Functions only. Clients must NEVER read or write here directly —
    // tokens are bearer credentials and the Admin SDK enforces all access.
    match /deviceSessions/{tokenHash} {
      allow read, write: if false;
    }

    // ==================== CALL LOGS ====================
    match /callLogs/{logId} {
      // Only participants can read their call logs
      allow read: if request.auth != null 
        && (resource.data.callerId == request.auth.uid 
            || resource.data.calleeId == request.auth.uid);
      
      // Only the caller or callee can create a call log
      allow create: if request.auth != null
        && (request.resource.data.callerId == request.auth.uid 
            || request.resource.data.calleeId == request.auth.uid);
      
      // Prevent updates and deletions
      allow update, delete: if false;
    }
  }
}
